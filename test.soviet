pow_result = 0
pow = (x, n) -> {
    pow_result = 1
    times(n, () -> {
        pow_result = pow_result * x
    })
}

factorial = (x) ->
    if x == 1
        then 1
        else x * factorial(x - 1)

invert = (bin) -> if bin == 0 then 1 else 0

sin_result = 0
sin = (x) -> {
    sin_result = 0

    current = 1
    result = 0
    plus = 1

    times(13, () -> {
        pow(x, current)
        new_value = (pow_result) / (factorial(current))
        current = current + 2
        if plus == 0
            then result = result - new_value
            else result = result + new_value
        plus = invert(plus)
    })

    sin_result = result
}

pi = 3.14159265359

degrees_to_radians = val -> val * pi / 180

angle = 30
sin(degrees_to_radians(angle))
print(sin_result)